# tools/youtube-upload/.env
#
# Worker token broker for YouTube uploads.
# The Worker route POST /v1/youtube/access-token reads from the SCALE YouTube
# OAuth integration's KV-stored token record. The SCALE OAuth flow must have
# been run at least once (browser-based consent at the SCALE admin UI) to
# seed the KV record before uploads can run.

WORKER_BASE_URL=https://api.virtuallaunch.pro

# Auth header value the Worker expects (full string including "Bearer ")
WORKER_AUTH_HEADER=Bearer <your-session-token-here>
