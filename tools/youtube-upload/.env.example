# Worker token broker
# The script POSTs to {WORKER_BASE_URL}/v1/youtube/access-token to get a
# fresh YouTube OAuth access token. Refresh token lives in Worker secrets.
WORKER_BASE_URL=https://api.virtuallaunch.pro

# Auth header value the Worker expects (full string including "Bearer ")
# Use the same auth pattern other admin endpoints use.
WORKER_AUTH_HEADER=Bearer <your-session-token-here>
