{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "signature"
  },
  "contract": {
    "authority": ["R2_VIRTUAL_LAUNCH"],
    "governs": "Authenticated operator CRUD for job posts — create, list active, update, and close; feeds public job listing and bulk email filters",
    "path": "contracts/operator-jobs.json",
    "source": "Virtual Launch Pro",
    "title": "Virtual Launch Pro — Operator Contract — Job Posts",
    "usedOnPages": ["/operator", "/operator.html"],
    "validation": {
      "enumStrict": true,
      "normalizeCheckboxToBoolean": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 1
  },
  "delivery": {
    "endpoint": "/operator/jobs",
    "method": "POST",
    "receiptKeyPattern": null,
    "receiptSource": null,
    "signature": {
      "header": "Authorization",
      "required": true,
      "secretEnvVar": "OPERATOR_SESSIONS"
    }
  },
  "effects": {
    "dedupeKey": "payload.eventId",
    "eventIdFrom": "payload.eventId",
    "writeOrder": ["canonicalUpsert"],
    "writes": ["job-posts"],
    "canonicalUpsert": {
      "target": "job-posts/{jobId}.json",
      "patchFrom": "effects.canonicalPatch"
    },
    "canonicalPatch": {
      "jobId":           "{payload.eventId}",
      "eventId":         "{payload.eventId}",
      "title":           "{payload.title}",
      "description":     "{payload.description}",
      "required_skills": "{payload.required_skills}",
      "status":          "open",
      "createdAt":       "{system.nowIso}",
      "updatedAt":       "{system.nowIso}"
    }
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "eventId":         { "type": "string", "minLength": 1 },
      "title":           { "type": "string", "minLength": 1, "maxLength": 200 },
      "description":     { "type": "string", "minLength": 1, "maxLength": 5000 },
      "required_skills": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Skill keys required for this role (e.g. skill_javascript)"
      },
      "budget":          { "type": "string", "maxLength": 100 },
      "duration":        { "type": "string", "maxLength": 100 }
    },
    "required": ["eventId", "title", "description"],
    "type": "object"
  },
  "response": {
    "deduped": { "deduped": true, "eventId": "{effects.eventIdFrom}", "ok": true },
    "error":   { "error": "validation_failed", "ok": false },
    "success": {
      "ok": true,
      "jobId": "{effects.canonicalPatch.jobId}",
      "eventId": "{effects.eventIdFrom}",
      "status": "open"
    }
  },
  "schema": {
    "name": "vlp_operator_jobs",
    "version": 1
  },
  "notes": {
    "authPattern": "Bearer token — see contracts/operator-auth.json",
    "dataSource": "R2 — job-posts/{jobId}.json",
    "publicReadContract": "GET /forms/jobs served by functions/forms/jobs.js (read-only, unauthenticated)",
    "additionalEndpoints": [
      {
        "name": "jobList",
        "endpoint": "/operator/jobs",
        "method": "GET",
        "description": "List all job posts. Optional filter: ?status=open|closed",
        "response": "{ ok, results: [{ jobId, title, status, createdAt, required_skills }] }"
      },
      {
        "name": "jobPatch",
        "endpoint": "/operator/jobs/{jobId}",
        "method": "PATCH",
        "description": "Update a job post. Mutable: title, description, required_skills, budget, duration, status. Setting status:closed removes from public listing.",
        "payload": "{ ...mutable fields (all optional) }",
        "effects": "Writes to R2 job-posts/{jobId}.json. Updates updatedAt.",
        "response": "{ ok, jobId, status, updatedAt }"
      }
    ],
    "cronTrigger": "New job post creation should trigger cron-job-match.json flow to match developers by required_skills"
  }
}
