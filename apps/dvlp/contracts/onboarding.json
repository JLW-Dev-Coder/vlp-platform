{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "session"
  },
  "contract": {
    "authority": ["R2_VIRTUAL_LAUNCH"],
    "governs": "Onboarding form submission (POST) and profile update (PATCH) for Virtual Launch Pro developers",
    "path": "contracts/onboarding.json",
    "source": "Virtual Launch Pro",
    "title": "Virtual Launch Pro — Form Contract — Onboarding",
    "usedOnPages": ["/public/onboarding.html"],
    "validation": {
      "enumStrict": true,
      "normalizeCheckboxToBoolean": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 2
  },
  "delivery": {
    "endpoint": "/forms/onboarding",
    "method": "POST",
    "receiptKeyPattern": "receipts/{source}/{eventId}.json",
    "receiptSource": "form",
    "signature": {
      "header": null,
      "required": false,
      "secretEnvVar": null
    }
  },
  "effects": {
    "dedupeKey": "payload.eventId",
    "eventIdFrom": "payload.eventId",
    "receiptAppend": { "to": "receipts/{source}/{eventId}.json" },
    "canonicalPatch": {
      "createdAt": "{system.nowIso}",
      "eventId": "{payload.eventId}",
      "recordId": "{payload.eventId}",
      "status": "pending",
      "updatedAt": "{system.nowIso}"
    },
    "canonicalUpsert": {
      "patchFrom": "effects.canonicalPatch",
      "target": "onboarding-records/{recordId}.json"
    },
    "writeOrder": ["receiptAppend", "canonicalUpsert"],
    "writes": ["onboarding-records"]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "eventId": { "minLength": 1, "type": "string" },
      "full_name": { "minLength": 1, "type": "string" },
      "email": { "minLength": 1, "type": "string" },
      "phone": { "type": "string" },
      "country": { "type": "string" },
      "linkedin_url": { "type": "string" },
      "portfolio_url": { "type": "string" },
      "video_url": { "type": "string" },
      "professional_summary": { "type": "string" },
      "hourly_rate": { "type": "string" },
      "availability": { "type": "string" },
      "contract_type": { "type": "string" },
      "timezone": { "type": "string" },
      "skill_javascript": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_python": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_react": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_nodejs": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_typescript": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_aws": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_docker": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_mongodb": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_postgresql": { "type": "integer", "minimum": 0, "maximum": 10 },
      "skill_other_skills": { "type": "string" },
      "ideal_role": { "type": "string" },
      "confirmation": { "type": "boolean" },
      "publish_profile": { "type": "boolean", "default": false, "filterable": true, "description": "Consent to publicly list developer profile" },
      "cronSchedule": { "type": "string", "enum": ["3 days", "7 days", "14 days"], "description": "How often to send job match notifications" },
      "status": { "type": "string", "enum": ["complete", "pending", "upcoming"], "description": "Candidate onboarding status" },
      "nextNotificationDue": { "type": "string", "format": "date-time", "description": "Computed from cronSchedule when status = complete" }
    },
    "required": ["eventId", "full_name", "email", "confirmation", "publish_profile"],
    "type": "object"
  },
  "response": {
    "deduped": { "deduped": true, "eventId": "{effects.eventIdFrom}", "ok": true },
    "error": { "error": "validation_failed", "ok": false },
    "success": { "eventId": "{effects.eventIdFrom}", "ok": true, "status": "pending" }
  },
  "patch": {
    "auth": {
      "required": true,
      "type": "session"
    },
    "delivery": {
      "endpoint": "/forms/onboarding",
      "method": "PATCH"
    },
    "effects": {
      "noNewReceipt": true,
      "target": "onboarding-records/{recordId}.json",
      "updatedAt": "{system.nowIso}",
      "preserves": ["createdAt", "eventId", "recordId"],
      "statusOverride": "only if status is explicitly included in PATCH payload"
    },
    "payload": {
      "additionalProperties": false,
      "type": "object",
      "required": ["ref_number"],
      "properties": {
        "ref_number":          { "type": "string", "minLength": 1, "description": "Record identifier — required to locate the R2 record" },
        "full_name":           { "type": "string" },
        "email":               { "type": "string" },
        "phone":               { "type": "string" },
        "country":             { "type": "string" },
        "linkedin_url":        { "type": "string" },
        "portfolio_url":       { "type": "string" },
        "video_url":           { "type": "string" },
        "professional_summary": { "type": "string" },
        "hourly_rate":         { "type": "string" },
        "availability":        { "type": "string" },
        "contract_type":       { "type": "string" },
        "timezone":            { "type": "string" },
        "skill_javascript":    { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_python":        { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_react":         { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_nodejs":        { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_typescript":    { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_aws":           { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_docker":        { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_mongodb":       { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_postgresql":    { "type": "integer", "minimum": 0, "maximum": 10 },
        "skill_other_skills":  { "type": "string" },
        "ideal_role":          { "type": "string" },
        "publish_profile":     { "type": "boolean" },
        "cronSchedule":        { "type": "string", "enum": ["3 days", "7 days", "14 days"] },
        "status":              { "type": "string", "enum": ["complete", "pending", "upcoming"] },
        "archived":            { "type": "boolean" },
        "archived_at":         { "type": "string", "format": "date-time" },
        "confirmation":        { "type": "boolean" }
      }
    },
    "response": {
      "success": { "ok": true, "eventId": "{effects.eventIdFrom}", "status": "{record.status}", "plan": "{record.plan}" },
      "error":   { "ok": false, "error": "not_found" }
    }
  },
  "schema": {
    "name": "vlp_form_onboarding",
    "version": 2
  }
}