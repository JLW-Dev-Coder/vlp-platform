      "ok": true,
      "payout_id": "{payout_id}",
      "amount": "{amount}",
      "status": "pending"
    },
    "error": {
      "error": "NOT_FOUND|CONNECT_REQUIRED|INSUFFICIENT_BALANCE|TRANSFER_FAILED|INTERNAL_ERROR",
      "ok": false,
      "message": "{error_message}"
    },
    "success": {
      "ok": true,
      "payout_id": "{payout_id}",
      "amount": "{amount}",
      "status": "pending"
    }
  },
  "schema": {
    "name": "vlp_affiliate_payout_request",
