{
  "auth": {
    "required": false,
    "trustClientIdentityFields": false,
    "type": "none"
  },
  "contract": {
    "authority": [
      "R2_VIRTUAL_LAUNCH"
    ],
    "governs": "VLP OIDC callback handling",
    "path": "/contracts/auth/auth.sso.oidc.callback.v1.json",
    "source": "Virtual Launch Pro",
    "title": "Virtual Launch Pro \u2014 Auth Sso Oidc Callback",
    "usedOnPages": [],
    "validation": {
      "enumStrict": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 1
  },
  "delivery": {
    "endpoint": "/v1/auth/sso/oidc/callback",
    "method": "GET",
    "receiptKeyPattern": "receipts/vlp/auth/sso/oidc/callback/{state}.json",
    "receiptSource": "auth_sso_oidc_callback",
    "signature": {
      "header": null,
      "required": false,
      "secretEnvVar": null
    }
  },
  "effects": {
    "canonicalUpsert": {
      "target": "accounts_vlp/VLP_ACCT_{recordId}.json"
    },
    "dedupeKey": "payload.state",
    "eventIdFrom": "payload.state",
    "receiptAppend": {
      "to": "receipts/vlp/auth/sso/oidc/callback/{state}.json"
    },
    "writeOrder": [
      "receiptAppend",
      "canonicalUpsert"
    ],
    "writes": [
      "accounts_vlp"
    ]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "code": {
        "minLength": 1,
        "type": "string"
      },
      "state": {
        "minLength": 1,
        "type": "string"
      }
    },
    "required": [
      "code",
      "state"
    ],
    "type": "object"
  },
  "response": {
    "deduped": {
      "deduped": true,
      "eventId": "{effects.eventIdFrom}",
      "ok": true
    },
    "error": {
      "error": "validation_failed",
      "ok": false
    },
    "success": {
      "ok": true,
      "status": "callback_completed"
    }
  },
  "schema": {
    "name": "auth_sso_oidc_callback",
    "version": 1
  }
}
