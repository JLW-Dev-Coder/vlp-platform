{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "session"
  },
  "contract": {
    "authority": [
      "R2_VIRTUAL_LAUNCH"
    ],
    "governs": "VLP two-factor authentication enrollment initialization",
    "path": "/contracts/auth/auth.2fa.enroll-init.v1.json",
    "source": "Virtual Launch Pro",
    "title": "Virtual Launch Pro \u2014 Auth 2Fa Enroll Init",
    "usedOnPages": [],
    "validation": {
      "enumStrict": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 1
  },
  "delivery": {
    "endpoint": "/v1/auth/2fa/enroll/init",
    "method": "POST",
    "receiptKeyPattern": "receipts/vlp/auth/2fa/enroll-init/{accountId}.json",
    "receiptSource": "auth_2fa_enroll_init",
    "signature": {
      "header": null,
      "required": false,
      "secretEnvVar": null
    }
  },
  "effects": {
    "canonicalUpsert": {
      "target": "accounts_vlp/VLP_ACCT_{accountId}.json"
    },
    "dedupeKey": "payload.accountId",
    "eventIdFrom": "payload.accountId",
    "receiptAppend": {
      "to": "receipts/vlp/auth/2fa/enroll-init/{accountId}.json"
    },
    "writeOrder": [
      "receiptAppend",
      "canonicalUpsert"
    ],
    "writes": [
      "accounts_vlp"
    ]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "accountId": {
        "minLength": 1,
        "type": "string"
      }
    },
    "required": [
      "accountId"
    ],
    "type": "object"
  },
  "response": {
    "deduped": {
      "deduped": true,
      "eventId": "{effects.eventIdFrom}",
      "ok": true
    },
    "error": {
      "error": "validation_failed",
      "ok": false
    },
    "success": {
      "accountId": "{payload.accountId}",
      "challenge": "{generated.totpSecret}",
      "ok": true,
      "status": "enrollment_started"
    }
  },
  "schema": {
    "name": "auth_2fa_enroll_init",
    "version": 1
  }
}
