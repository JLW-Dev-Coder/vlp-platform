{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "session"
  },
  "contract": {
    "authority": [
      "R2_VIRTUAL_LAUNCH"
    ],
    "governs": "VLP professional profile update",
    "path": "/contracts/profile/profile.update.v1.json",
    "source": "Virtual Launch Pro",
    "title": "Virtual Launch Pro \u2014 Profile Update",
    "usedOnPages": [],
    "validation": {
      "enumStrict": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 1
  },
  "delivery": {
    "endpoint": "/v1/profiles/{professionalId}",
    "method": "PATCH",
    "receiptKeyPattern": "receipts/vlp/profiles/update/{professionalId}.json",
    "receiptSource": "profile_update",
    "signature": {
      "header": null,
      "required": false,
      "secretEnvVar": null
    }
  },
  "effects": {
    "canonicalUpsert": {
      "target": "profiles/{professionalId}.json"
    },
    "dedupeKey": "payload.professionalId",
    "eventIdFrom": "payload.professionalId",
    "receiptAppend": {
      "to": "receipts/vlp/profiles/update/{professionalId}.json"
    },
    "writeOrder": [
      "receiptAppend",
      "canonicalUpsert"
    ],
    "writes": [
      "profiles"
    ]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "bio": {
        "maxLength": 5000,
        "minLength": 1,
        "type": "string"
      },
      "calBookingUrl": {
        "minLength": 1,
        "type": "string"
      },
      "displayName": {
        "minLength": 1,
        "type": "string"
      },
      "professionalId": {
        "minLength": 1,
        "type": "string"
      },
      "specialties": {
        "items": {
          "minLength": 1,
          "type": "string"
        },
        "minItems": 1,
        "type": "array"
      },
      "status": {
        "enum": [
          "active",
          "draft",
          "hidden"
        ],
        "type": "string"
      }
    },
    "required": [
      "professionalId"
    ],
    "type": "object"
  },
  "response": {
    "deduped": {
      "deduped": true,
      "eventId": "{effects.eventIdFrom}",
      "ok": true
    },
    "error": {
      "error": "validation_failed",
      "ok": false
    },
    "success": {
      "ok": true,
      "professionalId": "{payload.professionalId}",
      "status": "updated"
    }
  },
  "schema": {
    "name": "profile_update",
    "version": 1
  }
}
