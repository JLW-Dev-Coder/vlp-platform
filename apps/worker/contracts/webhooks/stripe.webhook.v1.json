{
  "auth": {
    "required": false,
    "trustClientIdentityFields": false,
    "type": "none"
  },
  "contract": {
    "authority": [
      "R2_VIRTUAL_LAUNCH"
    ],
    "governs": "VLP Stripe webhook receipt",
    "path": "/contracts/webhooks/stripe.webhook.v1.json",
    "source": "Virtual Launch Pro",
    "title": "Virtual Launch Pro \u2014 Webhooks Stripe Receive",
    "usedOnPages": [],
    "validation": {
      "enumStrict": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 1
  },
  "delivery": {
    "endpoint": "/v1/webhooks/stripe",
    "method": "POST",
    "receiptKeyPattern": "receipts/vlp/webhooks/stripe/{eventId}.json",
    "receiptSource": "stripe_webhook",
    "signature": {
      "header": "Stripe-Signature",
      "required": true,
      "secretEnvVar": "STRIPE_WEBHOOK_SECRET"
    }
  },
  "effects": {
    "canonicalUpsert": {
      "target": "memberships/{recordId}.json"
    },
    "dedupeKey": "payload.eventId",
    "eventIdFrom": "payload.eventId",
    "receiptAppend": {
      "to": "receipts/vlp/webhooks/stripe/{eventId}.json"
    },
    "writeOrder": [
      "receiptAppend",
      "canonicalUpsert"
    ],
    "writes": [
      "memberships"
    ]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {
      "eventId": {
        "minLength": 1,
        "type": "string"
      },
      "eventType": {
        "enum": [
          "checkout.session.completed",
          "customer.subscription.created",
          "customer.subscription.deleted",
          "customer.subscription.updated",
          "invoice.paid",
          "invoice.payment_failed",
          "payment_intent.payment_failed",
          "payment_intent.succeeded"
        ],
        "type": "string"
      },
      "stripeObjectId": {
        "minLength": 1,
        "type": "string"
      }
    },
    "required": [
      "eventId",
      "eventType",
      "stripeObjectId"
    ],
    "type": "object"
  },
  "response": {
    "deduped": {
      "deduped": true,
      "eventId": "{effects.eventIdFrom}",
      "ok": true
    },
    "error": {
      "error": "validation_failed",
      "ok": false
    },
    "success": {
      "eventId": "{payload.eventId}",
      "ok": true,
      "status": "received"
    }
  },
  "schema": {
    "name": "webhooks_stripe_receive",
    "version": 1
  }
}
