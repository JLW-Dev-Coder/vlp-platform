    "governs": "Reveal scratch ticket prize using weighted random",
    "path": "/contracts/wlvlp/wlvlp.scratch.reveal.v1.json",
    "source": "Website Lotto VLP",
    "title": "WLVLP — Scratch Ticket Reveal",
    "usedOnPages": ["/scratch/[ticket_id]"],
    "validation": {
      "enumStrict": false,
      "normalizeCheckboxToBoolean": false,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
