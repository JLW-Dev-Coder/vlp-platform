    "eventIdFrom": "ticket_id",
    "writeOrder": ["receipt", "canonical", "projection"],
    "writes": ["wlvlp_scratch_tickets"]
  },
  "payload": {
    "additionalProperties": false,
    "properties": {},
    "required": [],
    "type": "object"
  },
  "response": {
    "deduped": {
      "ok": false,
      "error": "TICKET_ALREADY_SCRATCHED"
    },
    "error": {
      "ok": false,
      "error": "TICKET_NOT_FOUND"
    },
    "success": {
      "ok": true,
      "prize_type": "free_month",
      "prize_value": "Free 1-month claim"
    }
  },
  "schema": {
    "name": "wlvlp_scratch_reveal",
    "version": 1
  }
