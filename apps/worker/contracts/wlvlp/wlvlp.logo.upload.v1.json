{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "session"
  },
  "contract": {
    "authority": ["R2_VIRTUAL_LAUNCH", "D1"],
    "governs": "Upload logo file for owned website template",
    "path": "/contracts/wlvlp/wlvlp.logo.upload.v1.json",
    "source": "Website Lotto VLP",
    "title": "WLVLP — Logo Upload",
    "usedOnPages": ["/dashboard/[slug]/edit"],
    "validation": {
      "enumStrict": false,
      "normalizeCheckboxToBoolean": false,
      "rejectUnknownValues": false,
      "requireJsonContentType": false
