  },
  "delivery": {
    "endpoint": "/v1/wlvlp/upload-logo",
    "method": "POST",
    "receiptKeyPattern": null,
    "receiptSource": null,
    "signature": {
      "header": null,
      "required": false,
      "secretEnvVar": null
    }
  },
  "effects": {
