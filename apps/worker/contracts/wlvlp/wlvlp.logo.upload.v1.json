    "required": ["file", "slug"],
    "type": "object"
  },
  "response": {
    "deduped": {
      "ok": true,
      "logo_url": "https://r2.virtuallaunch.pro/..."
    },
    "error": {
      "ok": false,
      "error": "UNAUTHORIZED"
    },
    "success": {
      "ok": true,
      "logo_url": "https://r2.virtuallaunch.pro/..."
    }
  },
  "schema": {
    "name": "wlvlp_logo_upload",
    "version": 1
