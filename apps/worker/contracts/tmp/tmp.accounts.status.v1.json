    },
    "success": {
      "ok": true,
      "status": {
        "phase": "string",
        "intake_complete": "number",
        "esign_2848_complete": "number",
        "processing_complete": "number",
        "tax_record_complete": "number",
        "current_step": "string",
        "step_status": "string",
        "notes": "string",
        "assigned_professional_id": "string"
      }
    }
  },
  "schema": {
    "name": "tmp_accounts_status",
    "version": 1
  }
}