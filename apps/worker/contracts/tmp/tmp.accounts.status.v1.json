{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "session"
  },
  "contract": {
    "authority": [
      "D1_DB",
      "R2_VIRTUAL_LAUNCH"
    ],
    "governs": "Account compliance status retrieval",
    "path": "/contracts/tmp/tmp.accounts.status.v1.json",
    "source": "Tax Monitor Pro",
