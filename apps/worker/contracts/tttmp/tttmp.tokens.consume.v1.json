{
  "auth": {
    "required": true,
    "type": "session",
    "trustClientIdentityFields": false
  },
  "contract": {
    "authority": "TTTMP",
    "governs": "Token consumption for TTMP transcript processing — deducts 1 token from account balance",
    "path": "/contracts/tttmp/tttmp.tokens.consume.v1.json",
    "source": "tttmp",
    "title": "TTTMP Tokens: Consume Token for Transcript Processing",
    "usedOnPages": ["/app/transcripts/preview", "/app/tools/transcript-parser"],
    "validation": "Validates account_id matches session, amount equals 1, sufficient balance exists",
    "version": "1.0"
  },
  "delivery": {
    "endpoint": "/v1/tokens/consume",
    "method": "POST",
    "receiptKeyPattern": "/receipts/ttmp/consume/{request_id}.json",
    "receiptSource": "R2_VIRTUAL_LAUNCH",
    "signature": "TTTMP_TOKEN_CONSUME_EXECUTED"
  },
  "effects": {
    "dedupeKey": "{request_id}",
    "eventIdFrom": "client",
    "writeOrder": [
      "receipt",
      "tokens_canonical_update",
      "tokens_d1_projection"
    ],
    "writes": [
      {
        "target": "R2",
        "key": "/receipts/ttmp/consume/{request_id}.json",
        "content": "Token consumption event metadata + balances"
      },
      {
        "target": "R2",
        "key": "/tokens/{account_id}.json",
        "content": "Updated canonical token balance"
      },
      {
        "target": "D1",
        "key": "tokens table",
        "content": "Updated token balance projection"
      }
    ]
  },
  "payload": {
    "type": "object",
    "required": ["account_id", "amount", "request_id"],
    "properties": {
      "account_id": {
        "type": "string",
        "pattern": "^ACCT_[a-f0-9-]+$",
        "description": "Must match authenticated session account ID"
      },
      "amount": {
        "type": "integer",
        "enum": [1],
        "description": "Token amount to consume (always 1 for transcript processing)"
      },
      "request_id": {
        "type": "string",
        "description": "UUID for deduplication - typically matches event_id from transcript job"
      }
    },
    "additionalProperties": false
  },
  "response": {
    "success": {
      "ok": true,
      "balance_after": 24,
      "request_id": "uuid-string"
    },
    "error": {
      "code": "VALIDATION_FAILED | UNAUTHORIZED | insufficient_balance",
      "message": "Human-readable error"
    },
    "deduped": {
      "ok": true,
      "message": "Duplicate request detected — returning cached response",
      "balance_after": 24,
      "request_id": "uuid-string"
    }
  },
  "schema": {
    "name": "tttmp.tokens.consume.v1",
    "version": "1.0"
  }
}