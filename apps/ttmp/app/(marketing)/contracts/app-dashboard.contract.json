{
  "auth": {
    "required": true,
    "trustClientIdentityFields": false,
    "type": "session"
  },
  "contract": {
    "authority": [
      "R2_TTMP_CANONICAL"
    ],
    "governs": "TTMP authenticated dashboard events",
    "path": "/contracts/app-dashboard.contract.json",
    "source": "Transcript Tax Monitor",
    "title": "Transcript Tax Monitor — App Dashboard Contract",
    "usedOnPages": [
      "/app/dashboard.html"
    ],
    "validation": {
      "enumStrict": true,
      "rejectUnknownValues": true,
      "requireJsonContentType": true
    },
    "version": 4
  },
  "events": {
    "claimReport": {
      "delivery": {
        "endpoint": "/api/transcripts/claim/{reportId}",
        "method": "POST"
      },
      "notes": [
        "Claims a previously saved report into the authenticated dashboard context."
      ],
      "request": {
        "additionalProperties": false,
        "properties": {},
        "required": [],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "claim_failed",
          "ok": false
        },
        "success": {
          "ok": true,
          "reportId": "{path.reportId}",
          "status": "claimed"
        }
      }
    },
    "getBalance": {
      "delivery": {
        "endpoint": "/api/transcripts/me",
        "method": "GET"
      },
      "request": {
        "additionalProperties": false,
        "properties": {},
        "required": [],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "session_required",
          "ok": false
        },
        "success": {
          "balance": 0,
          "ok": true,
          "tokenId": "acct_123"
        }
      }
    },
    "getPrices": {
      "delivery": {
        "endpoint": "/transcript/prices",
        "method": "GET"
      },
      "request": {
        "additionalProperties": false,
        "properties": {},
        "required": [],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "pricing_unavailable",
          "ok": false
        },
        "success": {
          "ok": true,
          "prices": []
        }
      }
    },
    "getPurchases": {
      "delivery": {
        "endpoint": "/api/transcripts/purchases",
        "method": "GET"
      },
      "request": {
        "additionalProperties": false,
        "properties": {},
        "required": [],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "history_unavailable",
          "ok": false
        },
        "success": {
          "ok": true,
          "purchases": []
        }
      }
    },
    "getReports": {
      "delivery": {
        "endpoint": "/api/transcripts/reports",
        "method": "GET"
      },
      "request": {
        "additionalProperties": false,
        "properties": {},
        "required": [],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "reports_unavailable",
          "ok": false
        },
        "success": {
          "ok": true,
          "reports": []
        }
      }
    },
    "getTokenLedger": {
      "delivery": {
        "endpoint": "/transcript/tokens",
        "method": "GET",
        "query": [
          "tokenId"
        ]
      },
      "request": {
        "additionalProperties": false,
        "properties": {
          "tokenId": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "tokenId"
        ],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "ledger_unavailable",
          "ok": false
        },
        "success": {
          "balance": 0,
          "ledger": [],
          "ok": true,
          "tokenId": "{query.tokenId}"
        }
      }
    },
    "savePreviewReport": {
      "delivery": {
        "endpoint": "/api/transcripts/preview",
        "method": "POST",
        "receiptKeyPattern": "receipts/ttmp/report_previews/{eventId}.json",
        "receiptSource": "ttmp_report_preview"
      },
      "effects": {
        "canonicalUpsert": {
          "target": "reports/{reportId}.json"
        },
        "eventIdFrom": "response.eventId",
        "receiptAppend": {
          "to": "receipts/ttmp/report_previews/{eventId}.json"
        },
        "writeOrder": [
          "receiptAppend",
          "canonicalUpsert"
        ],
        "writes": [
          "reports",
          "token_usage"
        ]
      },
      "request": {
        "additionalProperties": false,
        "properties": {
          "reportData": {
            "additionalProperties": true,
            "type": "object"
          }
        },
        "required": [
          "reportData"
        ],
        "type": "object"
      },
      "response": {
        "error": {
          "error": "preview_save_failed",
          "ok": false
        },
        "success": {
          "balance": 0,
          "eventId": "evt_123",
          "ok": true,
          "reportId": "rpt_123",
          "reportUrl": "/assets/report.html?reportId=rpt_123"
        }
      }
    }
  },
  "pages": {
    "account": {
      "contract": "account.contract.json",
      "pageId": "accountPage",
      "title": "Account"
    },
    "calendar": {
      "contract": "calendar.contract.json",
      "href": "/app/calendar.html",
      "title": "Calendar"
    },
    "parser": {
      "contract": "parse-lab.contract.json",
      "pageId": "dashboardPage",
      "title": "Parser"
    },
    "reports": {
      "contract": "report.contract.json",
      "pageId": "reportsPage",
      "title": "Reports"
    },
    "support": {
      "contract": "support.contract.json",
      "pageId": "supportPage",
      "title": "Support"
    },
    "token-usage": {
      "contract": "token-usage.contract.json",
      "href": "/app/token-usage.html",
      "title": "Token Usage"
    },
    "tokens": {
      "contract": "tokens.contract.json",
      "pageId": "receiptsPage",
      "title": "Tokens"
    }
  },
  "schema": {
    "name": "ttmp_app_dashboard",
    "version": 4
  }
}
