{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Reminder] Verify changes follow CLAUDE.md constraints before writing.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Reminder] Check output for errors before proceeding.'"
          }
        ]
      }
    ]
  }
}
